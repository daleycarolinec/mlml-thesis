      "cell_type": "markdown",
      "source": [
        "# Prepare Datsets"
      ],
      "metadata": {
        "id": "MkGwrqKibd_m"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "# import catch data collected by CCFRP\n",
        "ccfrp_catch = pd.read_csv(os.path.join(data_dir, 'raw_ccfrp_data.csv'))\n",
        "\n",
        "# import CCFRP sampling heirarchy metadata\n",
        "ccfrp_metadata = pd.read_csv(os.path.join(data_dir, 'ccfrp_metadata.csv'), encoding='latin1')\n",
        "\n",
        "# import xDEM generated habitat summaries\n",
        "habitat_df = pd.read_csv(os.path.join(data_dir, 'master_habitat_summary.csv'))"
      ],
      "metadata": {
        "id": "531uLmhLjq6f"
      },
      "execution_count": 106,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# calculate age since implementation of each MPA\n",
        "ccfrp_metadata['Age'] = 2026 - ccfrp_metadata['Implementation']\n",
        "\n",
        "# create a shared column between datsets\n",
        "ccfrp_catch['Area code'] = ccfrp_catch['Grid_Cell_ID'].str[0:2]\n",
        "\n",
        "# transfer age from metadata to catch data\n",
        "ccfrp_df = pd.merge(ccfrp_catch, ccfrp_metadata[['Area code', 'Age']], on='Area code', how='left')\n",
        "\n",
        "# remove data from before MPA was 5 years old\n",
        "ccfrp_df = ccfrp_df[ccfrp_df['Age']>=5]"
      ],
      "metadata": {
        "id": "3lA4JjfxmHaE"
      },
      "execution_count": 108,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "##  calculate catch per unit effort (CPUE) for each sampling drift ##\n",
        "ccfrp_df = pd.read_csv(os.path.join(data_dir, 'raw_ccfrp_data.csv'))\n",
        "\n",
        "# gather component parts to calculate CPUE\n",
        "cpue_summary = ccfrp_df.groupby(['Drift_ID', 'Grid_Cell_ID', 'Year']).agg(\n",
        "    unique_species_count=('Species_Code', 'count'),\n",
        "    total_angler_hours=('Total_Angler_Hrs', 'min') # angler hours are the same within a unique drift\n",
        ")\n",
        "\n",
        "# then, calculate CPUE for each fishing drift\n",
        "cpue_summary['CPUE'] = cpue_summary['unique_species_count'] / cpue_summary['total_angler_hours']\n",
        "\n",
        "# finally, calcualte average drift CPUE for each grid cell within a sampling year, then average between years within a grid cell\n",
        "gridcell_cpue = (\n",
        "    cpue_summary\n",
        "    .groupby(['Grid_Cell_ID', 'Year'])['CPUE'].mean()\n",
        "    .groupby('Grid_Cell_ID').mean()\n",
        "    .reset_index(name='mean_cpue')\n",
        ")\n",
        "\n",
        "#print(grid_cpue)"
      ],
      "metadata": {
        "id": "lb6Dkh59dvkJ"
      },
      "execution_count": 141,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# merege habitat and cpue datasets on shared spatial extent\n",
        "df = pd.merge(habitat_df, gridcell_cpue, on='Grid_Cell_ID', how='left')\n",
        "\n",
        "# remove rows where NaN values exist\n",
        "df = df.dropna()"
      ],
      "metadata": {
        "id": "TINqw2QNhgER"
      },
      "execution_count": 148,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "source": [
        "# Implement XGBoost Regressor"
      ],
      "metadata": {
        "id": "ux1QOAqlcb-Z"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "# Prepare design matrix\n",
        "X = np.column_stack([df.iloc[:, 4:56]])\n",
        "y = df['mean_cpue']"
      ],
      "metadata": {
        "id": "Y-LG1zdbbFe3"
      },
      "execution_count": 179,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# split data into training and testing sets\n",
        "X_train, X_test, y_train, y_test = train_test_split(X, y, test_size=0.3, random_state=17)"
      ],
      "metadata": {
        "id": "S4iwLesXvLGj"
      },
      "execution_count": 180,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# create the XGBoost Regression model here\n",
        "model = xgb.XGBRegressor(n_estimators = 200,\n",
        "                         max_depth = 10,\n",
        "                         random_state = 51,\n",
        "                         learning_rate = 0.05, # if our steps are too big, our model might blow up\n",
        "                         subsample = 0.6, # proportion of training data included in each model e.g. bootstrap\n",
        "                         colsample_bytree = 0.8) # proportion of columsn included in each model\n",
        "model.fit(X_train, y_train)"
